{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lonelydoctor/loyalty-radar/blob/main/plugins/loyalty-radar/skills/loyalty-radar/references/schemas/config.schema.json",
  "title": "Loyalty Radar user settings",
  "type": "object",
  "required": ["locale", "timezone", "region", "source_packs", "translation"],
  "properties": {
    "locale": {"enum": ["en", "zh-CN"]},
    "timezone": {"type": "string", "minLength": 1},
    "region": {"type": "string", "minLength": 1},
    "source_packs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9-]+$"}
    },
    "translation": {
      "type": "object",
      "required": ["provider"],
      "properties": {
        "provider": {"enum": ["google-public", "openai-compatible", "none"]},
        "model": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
