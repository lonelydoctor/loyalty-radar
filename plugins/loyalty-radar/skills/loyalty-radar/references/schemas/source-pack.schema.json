{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Loyalty Radar source pack",
  "type": "object",
  "required": ["pack", "sources"],
  "properties": {
    "pack": {
      "type": "object",
      "required": ["id", "name", "default_enabled"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "name": {"type": "string"},
        "description": {"type": "string"},
        "default_enabled": {"type": "boolean"}
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "priority", "fetch_method", "url", "default_limit", "rate_limit_seconds"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "priority": {"enum": ["P0", "P1", "P2"]},
          "fetch_method": {"enum": ["rss", "flyert_forum", "html_keyword", "browser_only"]},
          "url": {"type": "string", "format": "uri"},
          "default_limit": {"type": "integer", "minimum": 1},
          "rate_limit_seconds": {"type": "number", "minimum": 0}
        }
      }
    }
  }
}
